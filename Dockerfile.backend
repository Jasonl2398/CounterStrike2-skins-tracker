# BUILD
FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci
#RUN npm ci --omit=dev

# RUNTIME
FROM node:20-alpine

# tini for parent process (PID 1)
RUN apk add --no-cache tini wget curl

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules

COPY package.json ./
COPY server.js ./
COPY src/ ./src/

# Non-root user for security
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

EXPOSE 3001

ENTRYPOINT ["/sbin/tini", "--"]
# cmd ["npm","run","dev"]
CMD ["npm", "start"]
